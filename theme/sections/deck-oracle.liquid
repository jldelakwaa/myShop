{% liquid
  assign oracle_collection = section.settings.source_collection
  if oracle_collection == blank
    assign oracle_collection = collections.all
  endif
%}

<section id="deck-oracle" class="deck-oracle">
  <div class="deck-oracle__intro">
    <p class="arcana-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.copy }}</p>
  </div>

  <div class="deck-oracle__tool" data-deck-oracle>
    <div class="deck-oracle__controls">
      <div>
        <span>Playstyle</span>
        <button type="button" class="is-active" data-style="aggro">Aggro</button>
        <button type="button" data-style="control">Control</button>
        <button type="button" data-style="combo">Combo</button>
      </div>
      <div>
        <span>Attribute</span>
        <button type="button" class="is-active" data-attribute="dark">DARK</button>
        <button type="button" data-attribute="light">LIGHT</button>
        <button type="button" data-attribute="earth">EARTH</button>
        <button type="button" data-attribute="water">WATER</button>
        <button type="button" data-attribute="fire">FIRE</button>
        <button type="button" data-attribute="wind">WIND</button>
        <button type="button" data-attribute="divine">DIVINE</button>
      </div>
      <div>
        <span>Summon type</span>
        <button type="button" class="is-active" data-summon="normal">Normal</button>
        <button type="button" data-summon="tribute">Tribute</button>
        <button type="button" data-summon="fusion">Fusion</button>
        <button type="button" data-summon="synchro">Synchro</button>
        <button type="button" data-summon="xyz">Xyz</button>
        <button type="button" data-summon="pendulum">Pendulum</button>
        <button type="button" data-summon="link">Link</button>
        <button type="button" data-summon="ritual">Ritual</button>
      </div>
    </div>

    <div class="deck-oracle__result">
      <div
        class="deck-oracle__card"
        data-oracle-card
        {% if section.settings.card_image %}
          style="--oracle-image: url({{ section.settings.card_image | image_url: width: 700 }});"
        {% else %}
          style="--oracle-image: url({{ 'arcana-vault-hero.png' | asset_url }});"
        {% endif %}
      >
        <span data-oracle-rarity>Ultra Rare</span>
      </div>
      <div>
        <p class="deck-oracle__label" data-oracle-label>Aggro / DARK / Normal</p>
        <h3 data-oracle-title>Dark World Normal pressure deck</h3>
        <p data-oracle-copy>
          A pressure pick for duelists who want discard value, recursion, and consistent Normal Summon starters.
        </p>
        <a href="{{ section.settings.collection_link }}" data-oracle-link>Shop this build</a>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector("[data-deck-oracle]");
    if (!root) return;

    const oracleProducts = [
      {% for product in oracle_collection.products %}
        {% if product.featured_image %}
          {
            title: {{ product.title | json }},
            type: {{ product.type | json }},
            url: {{ product.url | json }},
            image: {{ product.featured_image | image_url: width: 700, height: 900, crop: 'center' | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endif %}
      {% endfor %}
    ].filter(Boolean);

    const playstyles = {
      aggro: {
        label: "Aggro",
        title: "pressure",
        copy: "fast openings, combat pressure, and a board that asks the opponent to answer immediately"
      },
      control: {
        label: "Control",
        title: "control",
        copy: "defensive tempo, disruption, and patient resource trades across longer duels"
      },
      combo: {
        label: "Combo",
        title: "engine",
        copy: "search chains, setup pieces, and puzzle turns that convert small starters into big payoffs"
      }
    };

    const attributes = {
      dark: ["DARK", "Dark World", "#6f55ff", "graveyard value and discard pressure", ["dark world", "dark", "shaddoll", "zombie"]],
      light: ["LIGHT", "Blue-Eyes", "#4d8dff", "boss monsters and clean tempo swings", ["blue-eyes", "light", "sanctuary"]],
      earth: ["EARTH", "Dinosmasher", "#b58a45", "board-breaking bodies and grounded pressure", ["dinosmasher", "dinosaur", "earth", "invincible fortress"]],
      water: ["WATER", "Sea Emperor", "#4ab8ff", "swarming lines and tempo control", ["sea emperor", "water", "freezing", "fury from the deep"]],
      fire: ["FIRE", "Fire Kings", "#ff6242", "destruction triggers and explosive comeback turns", ["fire kings", "fire", "soulburner", "blaze"]],
      wind: ["WIND", "Storm Lord", "#5bd9a0", "bounce effects and evasive board movement", ["storm", "wind"]],
      divine: ["DIVINE", "Sacred Vault", "#ffd66b", "mythic boss-card moments and collector appeal", ["sacred", "beast"]]
    };

    const summons = {
      normal: ["Normal", "consistent Normal Summon starters"],
      tribute: ["Tribute", "a Tribute Summon payoff"],
      fusion: ["Fusion", "a Fusion finish"],
      synchro: ["Synchro", "a Synchro ladder"],
      xyz: ["Xyz", "an Xyz toolbox"],
      pendulum: ["Pendulum", "Pendulum scaling"],
      link: ["Link", "Link climbing"],
      ritual: ["Ritual", "a Ritual boss route"]
    };

    let selectedStyle = "aggro";
    let selectedAttribute = "dark";
    let selectedSummon = "normal";

    const title = root.querySelector("[data-oracle-title]");
    const copy = root.querySelector("[data-oracle-copy]");
    const label = root.querySelector("[data-oracle-label]");
    const card = root.querySelector("[data-oracle-card]");
    const rarity = root.querySelector("[data-oracle-rarity]");
    const productLink = root.querySelector("[data-oracle-link]");

    function findProduct(attribute) {
      const keywords = attribute[4];

      return oracleProducts.find((product) => {
        const searchable = `${product.title} ${product.type}`.toLowerCase();

        return keywords.some((keyword) => searchable.includes(keyword));
      }) ?? oracleProducts[0];
    }

    function render() {
      const playstyle = playstyles[selectedStyle];
      const attribute = attributes[selectedAttribute];
      const summon = summons[selectedSummon];
      const product = findProduct(attribute);

      title.textContent = `${attribute[1]} ${summon[0]} ${playstyle.title} deck`;
      copy.textContent = `A ${playstyle.label.toLowerCase()} lane with ${attribute[3]}, ${playstyle.copy}, and ${summon[1]}.`;
      rarity.textContent = attribute[0];
      label.textContent = `${playstyle.label} / ${attribute[0]} / ${summon[0]}`;
      card.style.setProperty("--oracle-color", attribute[2]);

      if (product?.image) {
        card.style.setProperty("--oracle-image", `url(${product.image})`);
      }

      if (productLink && product?.url) {
        productLink.href = product.url;
      }
    }

    root.addEventListener("click", (event) => {
      const button = event.target.closest("button");
      if (!button) return;

      if (button.dataset.style) {
        selectedStyle = button.dataset.style;
        root.querySelectorAll("[data-style]").forEach((item) => item.classList.toggle("is-active", item === button));
      }

      if (button.dataset.attribute) {
        selectedAttribute = button.dataset.attribute;
        root.querySelectorAll("[data-attribute]").forEach((item) => item.classList.toggle("is-active", item === button));
      }

      if (button.dataset.summon) {
        selectedSummon = button.dataset.summon;
        root.querySelectorAll("[data-summon]").forEach((item) => item.classList.toggle("is-active", item === button));
      }

      render();
    });

    render();
  })();
</script>

{% stylesheet %}
  .deck-oracle {
    padding: clamp(56px, 8vw, 104px) 0;
  }

  .deck-oracle .arcana-eyebrow {
    color: #6a58d8;
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .deck-oracle__intro {
    max-width: 760px;
  }

  .deck-oracle__intro h2 {
    margin-top: 10px;
    color: #140f1f;
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: 1;
  }

  .deck-oracle__intro p:last-child {
    margin-top: 18px;
    color: #5f5870;
    line-height: 1.65;
  }

  .deck-oracle__tool {
    display: grid;
    grid-template-columns: minmax(260px, 0.7fr) minmax(0, 1.3fr);
    gap: 18px;
    margin-top: 30px;
  }

  .deck-oracle__controls,
  .deck-oracle__result {
    border: 1px solid rgba(106, 88, 216, 0.28);
    border-radius: 8px;
    background: #fff;
  }

  .deck-oracle__controls {
    display: grid;
    gap: 22px;
    padding: 22px;
  }

  .deck-oracle__controls span {
    display: block;
    margin-bottom: 10px;
    color: #6b627c;
    font-size: 0.84rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .deck-oracle__controls button {
    display: inline-flex;
    margin: 0 8px 8px 0;
    padding: 9px 12px;
    border: 1px solid #cfc8ef;
    border-radius: 999px;
    background: #fff;
    color: #1c1429;
    cursor: pointer;
  }

  .deck-oracle__controls button.is-active {
    border-color: #1c1429;
    background: #1c1429;
    color: #fff7df;
  }

  .deck-oracle__result {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 24px;
    padding: 24px;
  }

  .deck-oracle__card {
    position: relative;
    min-height: 252px;
    overflow: hidden;
    border: 3px solid #ffd66b;
    border-radius: 10px;
    background:
      linear-gradient(180deg, rgba(17, 10, 24, 0.08), rgba(17, 10, 24, 0.72)),
      linear-gradient(135deg, rgba(255, 255, 255, 0.22), transparent 34%, rgba(255, 255, 255, 0.12) 46%, transparent 54%),
      var(--oracle-image),
      #110a18;
    background-position: center;
    background-size: cover;
    box-shadow: 0 20px 60px rgba(28, 20, 41, 0.22);
  }

  .deck-oracle__card::before {
    content: "";
    position: absolute;
    inset: 18px;
    border: 1px solid rgba(255, 214, 107, 0.54);
    border-radius: 7px;
  }

  .deck-oracle__card span {
    position: absolute;
    right: 14px;
    bottom: 14px;
    left: 14px;
    color: #fff7df;
    font-weight: 800;
    text-align: center;
  }

  .deck-oracle__label {
    color: #6a58d8;
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .deck-oracle__result h3 {
    margin-top: 12px;
    color: #140f1f;
    font-size: clamp(1.7rem, 3vw, 3rem);
    line-height: 1.05;
  }

  .deck-oracle__result p[data-oracle-copy] {
    margin-top: 14px;
    color: #5f5870;
    line-height: 1.65;
  }

  .deck-oracle__result a {
    display: inline-flex;
    margin-top: 20px;
    color: #140f1f;
    font-weight: 800;
  }

  @media (max-width: 820px) {
    .deck-oracle__tool,
    .deck-oracle__result {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Deck oracle",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Interactive deck finder"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Let the vault choose your next deck"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Pick a playstyle, Attribute, and summon type. The oracle recommends a Structure Deck lane that matches the kind of duel you want to play."
    },
    {
      "type": "collection",
      "id": "source_collection",
      "label": "Product image collection"
    },
    {
      "type": "url",
      "id": "collection_link",
      "label": "Collection link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "card_image",
      "label": "Oracle card image"
    }
  ],
  "presets": [
    {
      "name": "Deck oracle"
    }
  ]
}
{% endschema %}

{% liquid
  assign oracle_collection = section.settings.source_collection
  if oracle_collection == blank
    assign oracle_collection = collections.all
  endif
%}

<section
  id="deck-oracle"
  class="deck-oracle"
  style="--oracle-bg-image: url({{ 'arcana-vault-hero.png' | asset_url }});"
>
  <div class="deck-oracle__inner">
    <div class="deck-oracle__intro">
      <p class="arcana-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
    </div>

    <div class="deck-oracle__tool" data-deck-oracle>
      <div class="deck-oracle__controls">
        <div>
          <span>Playstyle</span>
          <button type="button" class="is-active" data-style="aggro">Aggro</button>
          <button type="button" data-style="control">Control</button>
          <button type="button" data-style="combo">Combo</button>
        </div>
        <div>
          <span>Attribute</span>
          <button type="button" class="is-active" data-attribute="dark">DARK</button>
          <button type="button" data-attribute="light">LIGHT</button>
          <button type="button" data-attribute="earth">EARTH</button>
          <button type="button" data-attribute="water">WATER</button>
          <button type="button" data-attribute="fire">FIRE</button>
          <button type="button" data-attribute="wind">WIND</button>
          <button type="button" data-attribute="divine">DIVINE</button>
        </div>
        <div>
          <span>Summon type</span>
          <button type="button" class="is-active" data-summon="normal">Normal</button>
          <button type="button" data-summon="tribute">Tribute</button>
          <button type="button" data-summon="fusion">Fusion</button>
          <button type="button" data-summon="synchro">Synchro</button>
          <button type="button" data-summon="xyz">Xyz</button>
          <button type="button" data-summon="pendulum">Pendulum</button>
          <button type="button" data-summon="link">Link</button>
          <button type="button" data-summon="ritual">Ritual</button>
        </div>
      </div>

      <div class="deck-oracle__result">
        <div
          class="deck-oracle__card"
          data-oracle-card
          {% if section.settings.card_image %}
            style="--oracle-image: url({{ section.settings.card_image | image_url: width: 700 }});"
          {% else %}
            style="--oracle-image: url({{ 'arcana-vault-hero.png' | asset_url }});"
          {% endif %}
        >
          <span data-oracle-rarity>Ultra Rare</span>
        </div>
        <div>
          <p class="deck-oracle__label" data-oracle-label>Aggro / DARK / Normal</p>
          <h3 data-oracle-title>Dark World Normal pressure deck</h3>
          <p data-oracle-copy>
            A pressure pick for duelists who want discard value, recursion, and consistent Normal Summon starters.
          </p>
          <a class="deck-oracle__shop-link" href="{{ section.settings.collection_link }}" data-oracle-link>Shop this build</a>
        </div>

        <div class="deck-oracle__next">
          <span data-oracle-count>1 of 1</span>
          <button type="button" data-oracle-next>Next match</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector("[data-deck-oracle]");
    if (!root) return;

    const oracleProducts = [
      {% for product in oracle_collection.products %}
        {% if product.featured_image %}
          {
            title: {{ product.title | json }},
            type: {{ product.type | json }},
            url: {{ product.url | json }},
            image: {{ product.featured_image | image_url: width: 700 | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endif %}
      {% endfor %}
    ].filter(Boolean);

    const playstyles = {
      aggro: {
        label: "Aggro",
        title: "pressure",
        copy: "fast openings, combat pressure, and a board that asks the opponent to answer immediately"
      },
      control: {
        label: "Control",
        title: "control",
        copy: "defensive tempo, disruption, and patient resource trades across longer duels"
      },
      combo: {
        label: "Combo",
        title: "engine",
        copy: "search chains, setup pieces, and puzzle turns that convert small starters into big payoffs"
      }
    };

    const playstyleKeywords = {
      aggro: ["blue-eyes", "dragon", "fire", "dinosaur", "warrior", "hero", "kaiba", "soulburner", "beast"],
      control: ["dark world", "dark", "water", "sea", "light", "sanctuary", "spellcaster", "charmer", "underworld", "emperor"],
      combo: ["machine", "cyber", "pendulum", "link", "synchro", "synchron", "shaddoll", "albaz", "dragunity", "cyberse"]
    };

    const attributes = {
      dark: ["DARK", "Dark World", "#6f55ff", "graveyard value and discard pressure", ["dark world", "dark", "shaddoll", "zombie"]],
      light: ["LIGHT", "Blue-Eyes", "#4d8dff", "boss monsters and clean tempo swings", ["blue-eyes", "light", "sanctuary"]],
      earth: ["EARTH", "Dinosmasher", "#b58a45", "board-breaking bodies and grounded pressure", ["dinosmasher", "dinosaur", "earth", "invincible fortress"]],
      water: ["WATER", "Sea Emperor", "#4ab8ff", "swarming lines and tempo control", ["sea emperor", "water", "freezing", "fury from the deep"]],
      fire: ["FIRE", "Fire Kings", "#ff6242", "destruction triggers and explosive comeback turns", ["fire kings", "fire", "soulburner", "blaze"]],
      wind: ["WIND", "Storm Lord", "#5bd9a0", "bounce effects and evasive board movement", ["storm", "wind"]],
      divine: ["DIVINE", "Sacred Vault", "#ffd66b", "mythic boss-card moments and collector appeal", ["sacred", "beast"]]
    };

    const summons = {
      normal: ["Normal", "consistent Normal Summon starters"],
      tribute: ["Tribute", "a Tribute Summon payoff"],
      fusion: ["Fusion", "a Fusion finish"],
      synchro: ["Synchro", "a Synchro ladder"],
      xyz: ["Xyz", "an Xyz toolbox"],
      pendulum: ["Pendulum", "Pendulum scaling"],
      link: ["Link", "Link climbing"],
      ritual: ["Ritual", "a Ritual boss route"]
    };

    const summonKeywords = {
      normal: ["yugi", "kaiba", "blue-eyes", "warrior", "spellcaster"],
      tribute: ["tribute", "emperor", "kaiba", "marik", "beast"],
      fusion: ["fusion", "shaddoll", "albaz", "fallen", "hero", "cyber dragon"],
      synchro: ["synchro", "synchron", "5d", "dragunity"],
      xyz: ["xyz", "gear", "geargia"],
      pendulum: ["pendulum", "domination", "master of pendulum"],
      link: ["link", "cyberse", "powercode", "soulburner"],
      ritual: ["ritual", "spellcaster", "charmers"]
    };

    let selectedStyle = "aggro";
    let selectedAttribute = "dark";
    let selectedSummon = "normal";
    let selectedMatchIndex = 0;
    let currentMatches = [];

    const title = root.querySelector("[data-oracle-title]");
    const copy = root.querySelector("[data-oracle-copy]");
    const label = root.querySelector("[data-oracle-label]");
    const card = root.querySelector("[data-oracle-card]");
    const rarity = root.querySelector("[data-oracle-rarity]");
    const productLink = root.querySelector("[data-oracle-link]");
    const nextMatch = root.querySelector("[data-oracle-next]");
    const matchCount = root.querySelector("[data-oracle-count]");

    function scoreKeywords(searchable, keywords, weight) {
      return keywords.reduce((score, keyword) => (
        searchable.includes(keyword) ? score + weight : score
      ), 0);
    }

    function scoreProduct(product, playstyleKey, attribute, summonKey) {
      const searchable = `${product.title} ${product.type}`.toLowerCase();
      const attributeScore = scoreKeywords(searchable, attribute[4], 5);
      const summonScore = scoreKeywords(searchable, summonKeywords[summonKey] || [], 4);
      const playstyleScore = scoreKeywords(searchable, playstyleKeywords[playstyleKey] || [], 2);

      return {
        score: attributeScore + summonScore + playstyleScore,
        hasFilterMatch: attributeScore > 0 || summonScore > 0
      };
    }

    function findProducts(playstyleKey, attribute, summonKey) {
      return oracleProducts
        .map((product) => {
          const result = scoreProduct(product, playstyleKey, attribute, summonKey);

          return {
            product,
            score: result.score,
            hasFilterMatch: result.hasFilterMatch
          };
        })
        .filter((item) => item.hasFilterMatch)
        .sort((a, b) => b.score - a.score || a.product.title.localeCompare(b.product.title));
    }

    function renderProduct() {
      const playstyle = playstyles[selectedStyle];
      const attribute = attributes[selectedAttribute];
      const summon = summons[selectedSummon];
      const product = currentMatches[selectedMatchIndex]?.product ?? oracleProducts[0];

      title.textContent = `${attribute[1]} ${summon[0]} ${playstyle.title} deck`;
      copy.textContent = `A ${playstyle.label.toLowerCase()} lane with ${attribute[3]}, ${playstyle.copy}, and ${summon[1]}.`;
      rarity.textContent = attribute[0];
      label.textContent = `${playstyle.label} / ${attribute[0]} / ${summon[0]}`;
      card.style.setProperty("--oracle-color", attribute[2]);

      if (product?.image) {
        card.style.setProperty("--oracle-image", `url(${product.image})`);
      }

      if (productLink && product?.url) {
        productLink.href = product.url;
      }

      if (nextMatch) {
        nextMatch.disabled = currentMatches.length <= 1;
      }

      if (matchCount) {
        matchCount.textContent = `${selectedMatchIndex + 1} of ${Math.max(currentMatches.length, 1)}`;
      }
    }

    function resetMatches() {
      currentMatches = findProducts(selectedStyle, attributes[selectedAttribute], selectedSummon);

      if (currentMatches.length === 0 && oracleProducts[0]) {
        currentMatches = [{ product: oracleProducts[0], score: 0 }];
      }

      selectedMatchIndex = 0;
      renderProduct();
    }

    root.addEventListener("click", (event) => {
      const button = event.target.closest("button");
      if (!button) return;

      if (button.dataset.style) {
        selectedStyle = button.dataset.style;
        root.querySelectorAll("[data-style]").forEach((item) => item.classList.toggle("is-active", item === button));
        resetMatches();
        return;
      }

      if (button.dataset.attribute) {
        selectedAttribute = button.dataset.attribute;
        root.querySelectorAll("[data-attribute]").forEach((item) => item.classList.toggle("is-active", item === button));
        resetMatches();
        return;
      }

      if (button.dataset.summon) {
        selectedSummon = button.dataset.summon;
        root.querySelectorAll("[data-summon]").forEach((item) => item.classList.toggle("is-active", item === button));
        resetMatches();
      }
    });

    nextMatch?.addEventListener("click", () => {
      if (currentMatches.length <= 1) return;
      selectedMatchIndex = (selectedMatchIndex + 1) % currentMatches.length;
      renderProduct();
    });

    resetMatches();
  })();
</script>

{% stylesheet %}
  .deck-oracle {
    position: relative;
    left: 50%;
    width: 100vw;
    margin-left: -50vw;
    padding: clamp(56px, 8vw, 104px) 0;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(17, 10, 24, 0.94), rgba(17, 10, 24, 0.78) 52%, rgba(255, 214, 107, 0.22)),
      linear-gradient(180deg, rgba(17, 10, 24, 0.62), rgba(17, 10, 24, 0.96)),
      var(--oracle-bg-image);
    background-position: center;
    background-size: cover;
    color: #fff7df;
  }

  .deck-oracle::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 247, 223, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 247, 223, 0.05) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: linear-gradient(90deg, #000, transparent 72%);
    pointer-events: none;
  }

  .deck-oracle__inner {
    position: relative;
    z-index: 1;
    width: min(var(--page-width), calc(100vw - var(--page-margin) * 2));
    margin: 0 auto;
  }

  .deck-oracle .arcana-eyebrow {
    color: #ffd66b;
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .deck-oracle__intro {
    max-width: 760px;
  }

  .deck-oracle__intro h2 {
    margin-top: 10px;
    color: #fff7df;
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: 1;
  }

  .deck-oracle__intro p:last-child {
    margin-top: 18px;
    color: rgba(255, 247, 223, 0.78);
    line-height: 1.65;
  }

  .deck-oracle__tool {
    display: grid;
    grid-template-columns: minmax(260px, 0.7fr) minmax(0, 1.3fr);
    gap: 18px;
    margin-top: 30px;
  }

  .deck-oracle__controls,
  .deck-oracle__result {
    border: 1px solid rgba(255, 247, 223, 0.18);
    border-radius: 8px;
    background: rgba(255, 247, 223, 0.08);
    backdrop-filter: blur(18px);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
  }

  .deck-oracle__controls {
    display: grid;
    gap: 22px;
    padding: 22px;
  }

  .deck-oracle__controls span {
    display: block;
    margin-bottom: 10px;
    color: rgba(255, 247, 223, 0.76);
    font-size: 0.84rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .deck-oracle__controls button {
    display: inline-flex;
    margin: 0 8px 8px 0;
    padding: 9px 12px;
    border: 1px solid rgba(255, 247, 223, 0.24);
    border-radius: 999px;
    background: rgba(255, 247, 223, 0.08);
    color: #fff7df;
    cursor: pointer;
  }

  .deck-oracle__controls button.is-active {
    border-color: #ffd66b;
    background: #ffd66b;
    color: #140f1f;
  }

  .deck-oracle__result {
    position: relative;
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 24px;
    padding: 24px;
    padding-bottom: 74px;
  }

  .deck-oracle__card {
    position: relative;
    min-height: 300px;
    overflow: hidden;
    border: 1px solid rgba(255, 214, 107, 0.34);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(17, 10, 24, 0.04), rgba(17, 10, 24, 0.28)),
      var(--oracle-image),
      #110a18;
    background-position: center;
    background-size: contain;
    background-repeat: no-repeat;
    box-shadow: 0 20px 60px rgba(28, 20, 41, 0.22);
  }

  .deck-oracle__card::before {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: 45%;
    background: linear-gradient(180deg, transparent, rgba(17, 10, 24, 0.74));
    pointer-events: none;
  }

  .deck-oracle__card span {
    position: absolute;
    right: 12px;
    bottom: 12px;
    left: auto;
    padding: 6px 10px;
    border: 1px solid rgba(255, 214, 107, 0.46);
    border-radius: 999px;
    background: rgba(17, 10, 24, 0.74);
    color: #ffd66b;
    font-size: 0.78rem;
    font-weight: 800;
    text-align: center;
  }

  .deck-oracle__label {
    color: #ffd66b;
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .deck-oracle__result h3 {
    margin-top: 12px;
    color: #fff7df;
    font-size: clamp(1.7rem, 3vw, 3rem);
    line-height: 1.05;
  }

  .deck-oracle__result p[data-oracle-copy] {
    margin-top: 14px;
    color: rgba(255, 247, 223, 0.78);
    line-height: 1.65;
  }

  .deck-oracle__shop-link {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    margin-top: 20px;
    color: #ffd66b;
    font-weight: 800;
  }

  .deck-oracle__next {
    position: absolute;
    right: 24px;
    bottom: 22px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .deck-oracle__next button {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 12px;
    border: 1px solid #ffd66b;
    border-radius: 4px;
    background: transparent;
    color: #ffd66b;
    cursor: pointer;
    font-weight: 800;
  }

  .deck-oracle__next button:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .deck-oracle__next span {
    color: rgba(255, 247, 223, 0.68);
    font-size: 0.82rem;
    font-weight: 800;
  }

  @media (max-width: 820px) {
    .deck-oracle__tool,
    .deck-oracle__result {
      grid-template-columns: 1fr;
    }

    .deck-oracle__next {
      position: static;
      justify-content: flex-end;
      grid-column: 1;
      margin-top: 4px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Deck oracle",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Interactive deck finder"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Let the vault choose your next deck"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Pick a playstyle, Attribute, and summon type. The oracle recommends a Structure Deck lane that matches the kind of duel you want to play."
    },
    {
      "type": "collection",
      "id": "source_collection",
      "label": "Product image collection"
    },
    {
      "type": "url",
      "id": "collection_link",
      "label": "Collection link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "card_image",
      "label": "Oracle card image"
    }
  ],
  "presets": [
    {
      "name": "Deck oracle"
    }
  ]
}
{% endschema %}

{% liquid
  assign deck_collection = section.settings.deck_collection

  if deck_collection == blank
    assign deck_collection = collections.all
  endif
%}

<section class="structure-decks" id="structure-decks">
  <div class="structure-decks__header">
    <div>
      <p class="arcana-eyebrow">{{ section.settings.eyebrow }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.copy }}</p>
    </div>
    <div class="structure-decks__controls" aria-label="Structure deck carousel controls">
      <button type="button" data-carousel-prev>Prev</button>
      <button type="button" data-carousel-next>Next</button>
    </div>
  </div>

  <div class="structure-decks__viewport" data-structure-carousel>
    <div class="structure-decks__track" data-carousel-track>
      {% assign rendered_count = 0 %}

      {% paginate deck_collection.products by 100 %}
        {% for product in deck_collection.products %}
          {% if product.type contains 'Structure Deck' or product.tags contains 'Structure Deck' %}
            {% assign rendered_count = rendered_count | plus: 1 %}

            <article class="structure-deck-card">
              <a href="{{ product.url }}" aria-label="View {{ product.title | escape }}">
                {% if product.featured_image %}
                  {{
                    product.featured_image
                    | image_url: width: 700, height: 900, crop: 'center'
                    | image_tag: class: 'structure-deck-card__image', loading: 'lazy', alt: product.title
                  }}
                {% else %}
                  <div
                    class="structure-deck-card__fallback"
                    style="background-image: linear-gradient(180deg, rgba(18, 13, 27, 0.2), rgba(18, 13, 27, 0.82)), url({{ 'arcana-vault-hero.png' | asset_url }});"
                  >
                    <span>{{ product.title }}</span>
                  </div>
                {% endif %}
              </a>
              <div class="structure-deck-card__content">
                <span>{{ product.type | default: 'Structure Deck' }}</span>
                <h3>
                  <a href="{{ product.url }}">{{ product.title }}</a>
                </h3>
                <strong>{{ product.price | money }}</strong>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      {% endpaginate %}

      {% if rendered_count == 0 %}
        <article class="structure-deck-card structure-deck-card--empty">
          <div
            class="structure-deck-card__fallback"
            style="background-image: linear-gradient(180deg, rgba(18, 13, 27, 0.2), rgba(18, 13, 27, 0.82)), url({{ 'arcana-vault-hero.png' | asset_url }});"
          >
            <span>Import Structure Deck products to fill this carousel.</span>
          </div>
          <div class="structure-deck-card__content">
            <span>CSV ready</span>
            <h3>Upload the Structure Deck CSV</h3>
            <strong>55 decks</strong>
          </div>
        </article>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector("[data-structure-carousel]");
    if (!root) return;

    const track = root.querySelector("[data-carousel-track]");
    const section = root.closest(".structure-decks");
    const previous = section.querySelector("[data-carousel-prev]");
    const next = section.querySelector("[data-carousel-next]");
    let autoplay;

    function scrollByCard(direction) {
      const card = track.querySelector(".structure-deck-card");
      const distance = card ? card.getBoundingClientRect().width + 16 : 320;
      const maxScroll = track.scrollWidth - track.clientWidth;

      if (direction > 0 && track.scrollLeft >= maxScroll - 8) {
        track.scrollTo({
          left: 0,
          behavior: "smooth"
        });
        return;
      }

      track.scrollBy({
        left: direction * distance * 2,
        behavior: "smooth"
      });
    }

    function startAutoplay() {
      stopAutoplay();
      autoplay = window.setInterval(() => scrollByCard(1), 3000);
    }

    function stopAutoplay() {
      if (autoplay) {
        window.clearInterval(autoplay);
      }
    }

    previous.addEventListener("click", () => scrollByCard(-1));
    next.addEventListener("click", () => scrollByCard(1));
    root.addEventListener("mouseenter", stopAutoplay);
    root.addEventListener("mouseleave", startAutoplay);
    root.addEventListener("focusin", stopAutoplay);
    root.addEventListener("focusout", startAutoplay);

    startAutoplay();
  })();
</script>

{% stylesheet %}
  .structure-decks {
    padding: clamp(56px, 8vw, 104px) 0;
  }

  .structure-decks .arcana-eyebrow {
    color: #6a58d8;
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .structure-decks__header {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: end;
  }

  .structure-decks__header > div:first-child {
    max-width: 820px;
  }

  .structure-decks__header h2 {
    margin-top: 10px;
    color: #140f1f;
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: 1;
  }

  .structure-decks__header p:last-child {
    margin-top: 18px;
    color: #5f5870;
    line-height: 1.7;
  }

  .structure-decks__controls {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
  }

  .structure-decks__controls button {
    min-height: 40px;
    padding: 0 14px;
    border-color: #cfc8ef;
    background: #fff;
    color: #140f1f;
  }

  .structure-decks__viewport {
    margin-top: 32px;
  }

  .structure-decks__track {
    display: grid;
    grid-auto-columns: minmax(220px, 280px);
    grid-auto-flow: column;
    gap: 16px;
    overflow-x: auto;
    padding-bottom: 12px;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
  }

  .structure-deck-card {
    overflow: hidden;
    border: 1px solid rgba(106, 88, 216, 0.28);
    border-radius: 8px;
    background: #fff;
    scroll-snap-align: start;
  }

  .structure-deck-card > a {
    display: block;
    text-decoration: none;
  }

  .structure-deck-card__image,
  .structure-deck-card__fallback {
    aspect-ratio: 7 / 9;
    width: 100%;
  }

  .structure-deck-card__image {
    object-fit: cover;
  }

  .structure-deck-card__fallback {
    display: grid;
    place-items: center;
    padding: 18px;
    background:
      radial-gradient(circle at 50% 32%, rgba(106, 88, 216, 0.34), transparent 38%),
      #120d1b;
    color: #fff7df;
    text-align: center;
  }

  .structure-deck-card__fallback span {
    font-weight: 800;
  }

  .structure-deck-card__content {
    display: grid;
    gap: 8px;
    padding: 16px;
  }

  .structure-deck-card__content span {
    color: #6a58d8;
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .structure-deck-card__content h3 {
    min-height: 3.2em;
    color: #140f1f;
    font-size: 1.02rem;
    line-height: 1.18;
  }

  .structure-deck-card__content a {
    color: inherit;
    text-decoration: none;
  }

  .structure-deck-card__content strong {
    color: #140f1f;
  }

  @media (max-width: 720px) {
    .structure-decks__header {
      align-items: start;
      flex-direction: column;
    }

    .structure-decks__track {
      grid-auto-columns: minmax(210px, 74vw);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Structure deck carousel",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Browse the deck vault"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Structure decks by duel plan"
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Scroll the full Structure Deck catalog after importing products. The carousel uses Shopify product images, titles, product types, and prices from your store."
    },
    {
      "type": "collection",
      "id": "deck_collection",
      "label": "Deck collection"
    }
  ],
  "presets": [
    {
      "name": "Structure deck carousel"
    }
  ]
}
{% endschema %}

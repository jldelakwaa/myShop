<header class="arcana-header full-width">
  <h2 class="header__title">
    <a href="{{ routes.root_url }}">
      {{ section.settings.brand_label | default: shop.name }}
    </a>
  </h2>

  <div class="header__menu">
    <a href="{{ routes.all_products_collection_url }}">Products</a>
    <a href="{{ routes.root_url }}#structure-decks">Structure Decks</a>
    <a href="{{ routes.root_url }}#deck-oracle">Deck Finder</a>
    <a href="{{ routes.root_url }}#playset-guide">Buy Guide</a>
  </div>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <a
        class="header__account"
        href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
        aria-label="{% if customer %}Account{% else %}Sign in{% endif %}"
      >
        {{ 'icon-account.svg' | inline_asset_content }}
      </a>
    {% endif %}

    <a class="header__cart" href="{{ routes.cart_url }}" aria-label="Cart">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  .arcana-header {
    position: sticky;
    top: 0;
    z-index: 20;
    height: 4.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 0 var(--page-margin);
    border-bottom: 1px solid rgba(255, 214, 107, 0.22);
    background:
      linear-gradient(90deg, rgba(20, 15, 31, 0.94), rgba(20, 15, 31, 0.78)),
      rgba(20, 15, 31, 0.9);
    box-shadow: 0 18px 60px rgba(20, 15, 31, 0.16);
    backdrop-filter: blur(18px);
  }
  .arcana-header a {
    position: relative;
    text-decoration: none;
    color: #fff7df;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .header__title {
    font-size: 1.12rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .header__title a {
    min-height: 38px;
    padding-left: 14px;
    border-left: 3px solid #ffd66b;
    font-weight: 900;
  }
  .header__menu {
    flex: 1;
    justify-content: center;
  }
  .header__menu a {
    min-height: 38px;
    padding: 0 12px;
    border: 1px solid transparent;
    border-radius: 999px;
    color: rgba(255, 247, 223, 0.76);
    font-size: 0.94rem;
  }
  .header__menu a:hover {
    border-color: rgba(255, 214, 107, 0.36);
    background: rgba(255, 247, 223, 0.08);
    color: #fff7df;
  }
  .arcana-header a sup {
    position: absolute;
    top: -10px;
    right: -10px;
    display: grid;
    min-width: 18px;
    height: 18px;
    place-items: center;
    border-radius: 999px;
    background: #ffd66b;
    color: #140f1f;
    font-size: 0.72rem;
    overflow: hidden;
  }
  .arcana-header svg {
    width: 2rem;
    color: #fff7df;
  }
  .arcana-header .header__menu,
  .arcana-header .header__icons {
    display: flex;
    gap: 1rem;
  }
  .header__icons {
    align-items: center;
  }
  .header__icons a {
    display: grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border: 1px solid rgba(255, 247, 223, 0.14);
    border-radius: 999px;
    background: rgba(255, 247, 223, 0.08);
  }
  @media (max-width: 760px) {
    .arcana-header {
      height: auto;
      flex-wrap: wrap;
      padding-block: 16px;
    }
    .header__menu {
      order: 3;
      flex-basis: 100%;
      justify-content: flex-start;
      overflow-x: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "text",
      "id": "brand_label",
      "label": "Brand label",
      "default": "Arcana Vault"
    }
  ]
}
{% endschema %}

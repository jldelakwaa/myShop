<header class="arcana-header">
  <h2 class="header__title">
    {{ shop.name | link_to: routes.root_url }}
  </h2>

  <div class="header__menu">
    {% for link in section.settings.menu.links %}
      {{ link.title | link_to: link.url }}
    {% endfor %}
  </div>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a class="header__cart" href="{{ routes.cart_url }}" aria-label="Cart">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  .arcana-header {
    height: 5.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 1px solid #ded8f5;
    background: rgba(255, 252, 245, 0.94);
  }
  .arcana-header a {
    position: relative;
    text-decoration: none;
    color: #140f1f;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .header__title {
    font-size: 1.12rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .header__menu {
    flex: 1;
    justify-content: center;
  }
  .header__menu a {
    color: #6c647c;
    font-size: 0.94rem;
  }
  .header__menu a:hover {
    color: #140f1f;
  }
  .arcana-header a sup {
    position: absolute;
    top: -10px;
    right: -10px;
    display: grid;
    min-width: 18px;
    height: 18px;
    place-items: center;
    border-radius: 999px;
    background: #ffd66b;
    color: #140f1f;
    font-size: 0.72rem;
    overflow: hidden;
  }
  .arcana-header svg {
    width: 2rem;
  }
  .arcana-header .header__menu,
  .arcana-header .header__icons {
    display: flex;
    gap: 1rem;
  }
  .header__icons {
    align-items: center;
  }
  @media (max-width: 760px) {
    .arcana-header {
      height: auto;
      flex-wrap: wrap;
      padding-block: 16px;
    }
    .header__menu {
      order: 3;
      flex-basis: 100%;
      justify-content: flex-start;
      overflow-x: auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}

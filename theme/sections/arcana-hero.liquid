<section class="arcana-hero full-width">
  <div class="arcana-hero__media">
    <img
      src="{{ 'arcana-vault-hero.png' | asset_url }}"
      alt="Original fantasy trading cards, deck boxes, and booster packs on a collector table"
      width="1800"
      height="1100"
      loading="eager"
    >
  </div>

  <div class="arcana-hero__content">
    <p class="arcana-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p class="arcana-hero__copy">{{ section.settings.copy }}</p>

    <div class="arcana-hero__actions">
      <a class="arcana-button" href="{{ section.settings.primary_link }}">
        {{ section.settings.primary_label }}
      </a>
      <a class="arcana-button arcana-button--secondary" href="{{ section.settings.secondary_link }}">
        {{ section.settings.secondary_label }}
      </a>
    </div>

    <div class="arcana-hero__stats" aria-label="Arcana Vault collector highlights">
      <div>
        <strong>4</strong>
        <span>Duel archetypes</span>
      </div>
      <div>
        <strong>60</strong>
        <span>Card starter decks</span>
      </div>
      <div>
        <strong>1</strong>
        <span>Vault-ready build</span>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .arcana-hero {
    position: relative;
    min-height: min(780px, calc(100svh - 96px));
    overflow: hidden;
    color: #fff7df;
    background: #090711;
  }

  .arcana-hero__media {
    position: absolute;
    inset: 0;
  }

  .arcana-hero__media::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(8, 6, 16, 0.92), rgba(8, 6, 16, 0.54) 48%, rgba(8, 6, 16, 0.14)),
      linear-gradient(0deg, rgba(8, 6, 16, 0.78), rgba(8, 6, 16, 0.04) 52%);
  }

  .arcana-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .arcana-hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: end;
    min-height: min(780px, calc(100svh - 96px));
    max-width: 820px;
    padding: clamp(96px, 14vw, 180px) var(--page-margin) clamp(48px, 8vw, 84px);
  }

  .arcana-eyebrow {
    color: #8de8ff;
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .arcana-hero h1 {
    margin-top: 14px;
    max-width: 13ch;
    color: #fff7df;
    font-size: clamp(3rem, 8vw, 7.2rem);
    line-height: 0.92;
  }

  .arcana-hero__copy {
    max-width: 60ch;
    margin-top: 24px;
    color: rgba(255, 247, 223, 0.84);
    font-size: clamp(1rem, 1.35vw, 1.2rem);
    line-height: 1.6;
  }

  .arcana-hero__actions,
  .arcana-hero__stats {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .arcana-button {
    display: inline-flex;
    align-items: center;
    min-height: 46px;
    padding: 0 18px;
    border: 1px solid #ffd66b;
    border-radius: 4px;
    background: #ffd66b;
    color: #100914;
    font-weight: 800;
    text-decoration: none;
  }

  .arcana-button--secondary {
    border-color: rgba(141, 232, 255, 0.6);
    background: rgba(141, 232, 255, 0.12);
    color: #fff7df;
  }

  .arcana-hero__stats {
    gap: 24px;
    padding-top: 10px;
  }

  .arcana-hero__stats div {
    min-width: 138px;
  }

  .arcana-hero__stats strong,
  .arcana-hero__stats span {
    display: block;
  }

  .arcana-hero__stats strong {
    font-size: 1.5rem;
  }

  .arcana-hero__stats span {
    color: rgba(255, 247, 223, 0.72);
    font-size: 0.9rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Arcana hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Original duel decks and collector drops"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Open the vault. Build the duel."
    },
    {
      "type": "textarea",
      "id": "copy",
      "label": "Copy",
      "default": "Arcana Vault is a fictional trading card shop for original duelists, collectors, and deck tinkerers chasing foil pulls, starter decks, sleeves, and archetype bundles."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary label",
      "default": "Shop booster vault"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary label",
      "default": "Use the deck oracle"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Arcana hero"
    }
  ]
}
{% endschema %}
